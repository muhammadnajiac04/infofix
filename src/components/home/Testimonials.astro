---
const testimonials = [
  {
    name: 'Ahmed K.',
    role: 'Business Owner',
    text: 'AstroFix repaired my water-damaged MacBook in just 2 days when Apple told me I had to buy a new one. Highly recommended!',
    rating: 5
  },
  {
    name: 'Sarah M.',
    role: 'Designer',
    text: 'Replaced my Dell XPS screen the same day. The customer service was exceptional and the price was very reasonable.',
    rating: 5
  },
  {
    name: 'Omar H.',
    role: 'Student',
    text: 'Recovered all my university files from a dead hard drive. Absolutely saved my life! Best data recovery in Qatar.',
    rating: 5
  }
];
---
<section class="section-padding bg-gray-bg border-b border-border-light">
  <div class="container mx-auto px-6">
    <div class="text-center mb-16 max-w-2xl mx-auto">
      <p class="text-primary font-bold uppercase tracking-widest mb-2 text-sm">Our Happy Customers</p>
      <h2 class="text-3xl md:text-5xl font-black text-dark mb-4 tracking-tight">Hear from them</h2>
      <p class="text-gray-600">Trusted by hundreds of individuals and businesses across Qatar.</p>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {testimonials.map(t => (
        <div class="bg-white p-8 rounded-xl border border-border-light shadow-sm relative hover:shadow-lg transition-all">
          <div class="text-primary text-5xl font-serif absolute top-4 left-6 opacity-20">"</div>
          <p class="text-gray-600 italic mb-6 mt-4 relative z-10 text-sm leading-relaxed">{t.text}</p>
          <div class="flex items-center justify-between border-t border-border-light pt-4">
            <div>
              <h4 class="text-dark font-bold">{t.name}</h4>
              <p class="text-gray-500 text-xs">{t.role}</p>
            </div>
            <div class="flex text-yellow-400">
              {Array.from({length: t.rating}).map(() => <span>★</span>)}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
