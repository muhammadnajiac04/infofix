---
---
<section class="py-12 md:py-16 bg-white overflow-hidden mt-[76px]">
  <div class="container mx-auto px-4 md:px-6">
    <div class="flex flex-col md:flex-row justify-between items-center mb-8">
      
      <!-- Left side text -->
      <div class="md:w-2/3 mb-6 md:mb-0">
        <h6 class="text-sm font-semibold mb-2 flex items-center text-dark animate-fade-in">
          Services We Offer
          <img src="/img/group-1.png" alt="Procedure Icon" class="ml-2 w-5 h-5">
        </h6>
        <h2 class="text-3xl md:text-5xl font-bold text-dark animate-fade-in-up leading-tight">
          Comprehensive<br>
          Repair Services at your Fingertips
        </h2>
      </div>
      
      <!-- Right side phone -->
      <div class="md:w-1/3 flex md:justify-end animate-fade-in-up">
        <div class="flex items-center gap-3">
          <a href="tel:+974 3097 5205" class="flex-shrink-0 w-12 h-12 bg-primary rounded-full flex items-center justify-center text-white">
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 16 16"><path fill-rule="evenodd" d="M1.885.511a1.745 1.745 0 0 1 2.61.163L6.29 2.98c.329.423.445.974.315 1.494l-.547 2.19a.678.678 0 0 0 .178.643l2.457 2.457a.678.678 0 0 0 .644.178l2.189-.547a1.745 1.745 0 0 1 1.494.315l2.306 1.794c.829.645.905 1.87.163 2.611l-1.034 1.034c-.74.74-1.846 1.065-2.877.702a18.634 18.634 0 0 1-7.01-4.42 18.634 18.634 0 0 1-4.42-7.009c-.362-1.03-.037-2.137.703-2.877L1.885.511z"/></svg>
          </a>
          <div>
            <span class="text-gray-500 text-sm block">Need Help?</span>
            <span class="font-bold text-dark text-lg tracking-wide block" dir="ltr">+974 3097 5205</span>
          </div>
        </div>
      </div>
    </div>
    
    <!-- 3 Cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <!-- Card 1 -->
      <div class="bg-white border border-gray-100 rounded-lg shadow-sm hover:shadow-md transition-shadow h-full flex flex-col animate-fade-in-up">
        <div class="p-6 pb-2">
          <img src="/img/laptop-logo.png" alt="Laptop Repair" class="w-full h-auto object-contain">
        </div>
        <div class="p-6 pt-2 flex-grow">
          <h3 class="text-xl font-bold text-dark mb-3">Laptop Repair Services</h3>
          <p class="text-gray-600 text-sm leading-relaxed">Facing issues with your Laptop? From Screen replacements to battery problems, our staff of experts handles everything so your device runs like new once again.</p>
        </div>
      </div>
      
      <!-- Card 2 -->
      <div class="bg-white border border-gray-100 rounded-lg shadow-sm hover:shadow-md transition-shadow h-full flex flex-col animate-fade-in-up" style="animation-delay: 100ms;">
        <div class="p-6 pb-2">
          <img src="/img/phone-logo.png" alt="Phone Repair" class="w-full h-auto object-contain">
        </div>
        <div class="p-6 pt-2 flex-grow">
          <h3 class="text-xl font-bold text-dark mb-3">Mobile Phone Repairs</h3>
          <p class="text-gray-600 text-sm leading-relaxed">From broken screens to connectivity issues, we offer professional mobile phone repairs to have you back connected without delays.</p>
        </div>
      </div>
      
      <!-- Card 3 -->
      <div class="bg-white border border-gray-100 rounded-lg shadow-sm hover:shadow-md transition-shadow h-full flex flex-col animate-fade-in-up" style="animation-delay: 200ms;">
        <div class="p-6 pb-2">
          <img src="/img/iphone-logo.png" alt="iPad Repair" class="w-full h-auto object-contain">
        </div>
        <div class="p-6 pt-2 flex-grow">
          <h3 class="text-xl font-bold text-dark mb-3">IPad Repairs</h3>
          <p class="text-gray-600 text-sm leading-relaxed">Don't allow problems with the iPad to slow you down. We provide reliable and reasonably priced iPad repair solutions from hardware failure to software bugs to a shattered screen.</p>
        </div>
      </div>
    </div>
  </div>
</section>
