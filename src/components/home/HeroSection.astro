---
---
<section class="relative min-h-screen pt-20 bg-dark text-white flex items-center overflow-hidden">
  <!-- Background Glow -->
  <div class="absolute top-1/2 left-1/4 -translate-x-1/2 -translate-y-1/2 w-96 h-96 bg-primary/20 rounded-full blur-[100px] -z-10"></div>
  <div class="absolute bottom-0 right-1/4 translate-x-1/4 w-96 h-96 bg-secondary/20 rounded-full blur-[100px] -z-10"></div>

  <div class="container mx-auto grid lg:grid-cols-2 gap-12 px-6 py-20 z-10">
    <div class="flex flex-col justify-center">
      <p class="text-primary font-bold uppercase tracking-widest mb-4">Qatar’s Trusted Laptop Experts</p>
      <h1 class="text-5xl md:text-7xl font-extrabold leading-tight tracking-tight">
        Laptop Sales &<br/> <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary to-secondary">Expert Repair</span>
      </h1>
      <p class="mt-6 text-lg text-gray-300 max-w-xl leading-relaxed">
        Premium laptops, genuine parts, chip-level repairs, and same-day diagnostics. Experience the best technology service in Doha.
      </p>
      <div class="flex flex-wrap gap-4 mt-8">
        <a href="/sales" class="bg-primary hover:bg-indigo-500 text-white font-semibold px-8 py-4 rounded-xl shadow-[0_0_15px_rgba(79,70,229,0.45)] transition-all hover:-translate-y-1">
          Shop Laptops
        </a>
        <a href="/repair" class="glass border border-borderGlass hover:bg-white/5 text-white font-semibold px-8 py-4 rounded-xl transition-all hover:-translate-y-1">
          Repair My Device
        </a>
      </div>
      
      <div class="mt-12 flex items-center gap-6 text-sm text-gray-400">
        <div class="flex items-center gap-2">
          <span class="text-green-400">✓</span> 3-Month Warranty
        </div>
        <div class="flex items-center gap-2">
          <span class="text-green-400">✓</span> Same-Day Service
        </div>
      </div>
    </div>
    
    <div class="relative flex items-center justify-center">
      <div class="glass w-full rounded-[2rem] p-8 border border-borderGlass shadow-[0_0_30px_rgba(79,70,229,0.2)]">
        <img src="/images/hero-laptop.png" alt="Premium Laptop showcase Qatar" class="w-full h-auto object-contain drop-shadow-2xl hover:scale-105 transition-transform duration-500" loading="eager" width="700" height="500" />
      </div>
      
      <!-- Trust Badge Floating -->
      <div class="absolute -bottom-6 -left-6 glass border border-borderGlass p-4 rounded-xl flex items-center gap-4 animate-bounce-slow">
        <div class="bg-primary rounded-full p-2">
          <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg>
        </div>
        <div>
          <p class="text-white font-bold text-sm">Certified</p>
          <p class="text-gray-400 text-xs">Technicians</p>
        </div>
      </div>
    </div>
  </div>
</section>
