---
const steps = [
  {
    number: '1',
    title: 'Book Your Repair',
    description: 'You can call our staff directly or book your free consultation on our website.'
  },
  {
    number: '2',
    title: 'Diagnosis & Assessment',
    description: 'To find the issue, our professionals quickly and thoroughly examine.'
  },
  {
    number: '3',
    title: 'Quick & Effective Repair',
    description: 'Once the issue has been identified, we quickly and effectively carry out the repairs to guarantee little downtime.'
  },
  {
    number: '4',
    title: 'Quality Assurance & Delivery',
    description: 'After the repair is finished, we examine your gadget to make sure it is operating as it should then send it back to you.'
  }
];
---
<section class="py-12 md:py-16 bg-white overflow-hidden">
  <div class="container mx-auto px-4 md:px-6">
    <div class="mb-10 text-center md:text-left">
      <h6 class="text-sm font-semibold mb-2 flex items-center justify-center md:justify-start text-dark animate-fade-in">
        Our Repairing Process
        <img src="/img/group-1.png" alt="Procedure Icon" class="ml-2 w-5 h-5">
      </h6>
      <h2 class="text-3xl md:text-5xl font-bold text-dark animate-fade-in-up">
        Simple, Straight Forward Repair Process
      </h2>
      <p class="text-gray-600 mt-4 max-w-3xl animate-fade-in-up" style="animation-delay: 100ms;">
        Our repair procedure is meant to be flawless, quick, and open to providing you the greatest experience:
      </p>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
      {steps.map((step, index) => (
        <div class="relative bg-light rounded-[30px] p-6 pt-10 mt-6 shadow-sm hover:shadow-md transition-shadow animate-fade-in-up" style={`animation-delay: ${index * 100}ms;`}>
          <!-- Floating Step Number -->
          <div class="absolute -top-6 left-6 w-12 h-12 bg-primary rounded-full flex items-center justify-center text-white text-xl font-bold shadow-md">
            {step.number}
          </div>
          <h5 class="text-lg font-bold text-dark mb-3">{step.title}</h5>
          <p class="text-gray-600 text-sm leading-relaxed">{step.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
