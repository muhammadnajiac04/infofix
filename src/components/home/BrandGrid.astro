---
const brands = [
  { name: 'HP', logo: '/img/hp-icon.svg' },
  { name: 'Asus', logo: '/img/asus-icon.svg' },
  { name: 'Surface Pro', logo: '/img/surface-icon.svg' },
  { name: 'Lenovo', logo: '/img/lenovo-icon.svg' },
  { name: 'Apple', logo: '/img/apple-icon.svg' },
  { name: 'Acer', logo: '/img/acer-icon.svg' },
  { name: 'Razer Blade', logo: '/img/razer-icon.svg' }
];
---
<section class="py-12 md:py-16 bg-white border-b border-gray-100">
  <div class="container mx-auto px-4 md:px-6">
    <div class="flex flex-col md:flex-row justify-between items-center mb-8">
      <div class="md:text-left text-center mb-4 md:mb-0">
        <h2 class="text-2xl md:text-4xl font-bold text-dark animate-fade-in">Brands We Repair</h2>
      </div>
      <div>
        <a href="/en" class="text-primary font-bold hover:underline">View All Brands</a>
      </div>
    </div>
    
    <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-7 gap-4">
      {brands.map((brand, index) => (
        <a href={`/en/brands/${brand.name.toLowerCase().replace(' ', '-')}`} class="border border-gray-200 rounded-lg p-4 flex items-center justify-center hover:shadow-md transition-shadow h-24 animate-fade-in-up" style={`animation-delay: ${index * 100}ms;`}>
          <img src={brand.logo} alt={brand.name} class="max-h-12 w-auto object-contain">
        </a>
      ))}
    </div>
  </div>
</section>
