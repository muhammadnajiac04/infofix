---
const features = [
  {
    title: 'Certified Technicians',
    description: 'Our team of experts guarantees your gadget is in capable hands by specializing in iPad, laptop, and mobile diagnostics and repairs.',
    icon: '/img/certified.svg'
  },
  {
    title: 'Rapid Turnaround',
    description: 'Usually finished in 24 to 48 hours, most repairs allow you to resume your regular activities without interruption.',
    icon: '/img/rapid.svg'
  },
  {
    title: 'Transparent & Affordable Pricing',
    description: 'We value honest service free from any hidden costs. You pay just for the repairs you really need—nothing more.',
    icon: '/img/pricing.svg'
  },
  {
    title: 'Proven Expertise',
    description: 'Having years of expertise, we have developed a reliable, professional, and precise reputation.',
    icon: '/img/expertise.svg'
  }
];
---
<section class="py-12 md:py-16 bg-light">
  <div class="container mx-auto px-4 md:px-6">
    <div class="mb-8">
      <h6 class="text-sm font-semibold mb-2 flex items-center text-dark animate-fade-in">
        Why Choose Us
        <img src="/img/group-1.png" alt="Procedure Icon" class="ml-2 w-5 h-5">
      </h6>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
      {features.map((feature, index) => (
        <div class="bg-white border border-gray-100 rounded-lg shadow-sm hover:shadow-md transition-shadow p-6 flex flex-col animate-fade-in-up" style={`animation-delay: ${index * 100}ms;`}>
          <div class="flex items-center gap-3 mb-4">
            <img src={feature.icon} alt="Feature Icon" class="w-10 h-10 object-contain">
            <h3 class="text-lg font-bold text-dark leading-tight">{feature.title}</h3>
          </div>
          <p class="text-gray-600 text-sm leading-relaxed">{feature.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
