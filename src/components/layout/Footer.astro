---
const year = new Date().getFullYear();
---
<footer class="bg-black text-white">
  <div class="container mx-auto px-4 md:px-6">
    <!-- Top Support Section -->
    <div class="grid md:grid-cols-2 py-8 gap-6 md:gap-0 items-center">
      <div class="flex items-center">
        <img src="/img/support_icon.png" alt="Support Icon" class="w-12 h-12 mr-4 animate-bounce">
        <h2 class="text-xl md:text-2xl font-bold animate-fade-in">Need Any Support For Your Device?</h2>
      </div>
      <div class="flex items-center md:border-l md:border-gray-700 md:pl-10">
        <img src="/img/whatsapp-icon.png" alt="WhatsApp Icon" class="w-12 h-12 mr-4 animate-bounce">
        <h2 class="text-xl md:text-2xl font-bold animate-fade-in">
          WhatsApp Us <span class="block tracking-wide" dir="ltr">+974 3097 5205</span>
        </h2>
      </div>
    </div>
    
    <hr class="border-gray-800 m-0">
    
    <!-- Main Footer Content -->
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8 py-12">
      <!-- Brand & Social -->
      <div class="text-center md:text-left">
        <img src="/img/logo-white.svg" alt="ScorpionFix Logo" class="w-48 mb-6 mx-auto md:mx-0">
        <div class="flex justify-center md:justify-start gap-3">
          <a href="#" class="w-10 h-10 bg-primary text-white rounded-full flex items-center justify-center hover:bg-white hover:text-primary transition-colors">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"></path></svg>
          </a>
          <a href="#" class="w-10 h-10 bg-primary text-white rounded-full flex items-center justify-center hover:bg-white hover:text-primary transition-colors">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37zm1.5-4.87h.01"></path></svg>
          </a>
        </div>
      </div>
      
      <!-- Services -->
      <div>
        <h5 class="text-lg font-bold mb-4">Services</h5>
        <ul class="space-y-2">
          <li><a href="/repair" class="text-gray-400 hover:text-primary transition-colors text-sm">Laptop repair</a></li>
          <li><a href="/repair" class="text-gray-400 hover:text-primary transition-colors text-sm">MacBook repair</a></li>
          <li><a href="/repair" class="text-gray-400 hover:text-primary transition-colors text-sm">Dell repair</a></li>
          <li><a href="/repair" class="text-gray-400 hover:text-primary transition-colors text-sm">HP repair</a></li>
          <li><a href="/repair" class="text-gray-400 hover:text-primary transition-colors text-sm">Acer repair</a></li>
        </ul>
      </div>
      
      <!-- Quick Links -->
      <div>
        <h5 class="text-lg font-bold mb-4">Useful Links</h5>
        <ul class="space-y-2">
          <li><a href="/about" class="text-gray-400 hover:text-primary transition-colors text-sm">About us</a></li>
          <li><a href="/sales" class="text-gray-400 hover:text-primary transition-colors text-sm">Shop Laptops</a></li>
          <li><a href="/contact" class="text-gray-400 hover:text-primary transition-colors text-sm">Contact us</a></li>
          <li><a href="#" class="text-gray-400 hover:text-primary transition-colors text-sm">Privacy Policy</a></li>
        </ul>
      </div>
      
      <!-- Contact -->
      <div>
        <h5 class="text-lg font-bold mb-4">Get in touch with us</h5>
        <ul class="space-y-4">
          <li class="flex items-start text-sm text-gray-400">
            <svg class="w-5 h-5 text-primary mr-3 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"></path></svg>
            63 Sofitel Complex, Wadi Msheireb St, Doha, qatar
          </li>
          <li class="flex items-center text-sm text-gray-400">
            <svg class="w-5 h-5 text-primary mr-3 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z"></path></svg>
            +974 3097 5205
          </li>
          <li class="flex items-center text-sm text-gray-400">
            <svg class="w-5 h-5 text-primary mr-3 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path d="M2.003 5.884L10 9.882l7.997-3.998A2 2 0 0016 4H4a2 2 0 00-1.997 1.884z"></path><path d="M18 8.118l-8 4-8-4V14a2 2 0 002 2h12a2 2 0 002-2V8.118z"></path></svg>
            info@scorpionfixqa.com
          </li>
        </ul>
      </div>
    </div>
    
    <!-- Copyright Bottom -->
    <div class="border-t border-gray-800 py-4 text-center text-sm text-gray-500">
      <p class="mb-0">© Scorpionfixqa.com 2026. All Rights Reserved.</p>
    </div>
  </div>
</footer>
