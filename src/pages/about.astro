---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout
  title="About AstroFix | Laptop Experts Qatar"
  description="Learn about our team of expert technicians and our mission to provide the best laptop repair services in Qatar."
>
  <div class="pt-32 pb-20 container mx-auto px-6">
    <div class="max-w-4xl mx-auto text-center">
      <h1 class="text-4xl md:text-6xl font-bold mb-6 text-white">About AstroFix</h1>
      <p class="text-xl text-gray-400 mb-12">Qatar's leading destination for premium laptop sales and professional repair services.</p>
    </div>
    
    <div class="grid md:grid-cols-2 gap-12 items-center mt-12">
      <div class="glass p-8 rounded-3xl border border-borderGlass shadow-neon">
        <h2 class="text-3xl font-bold text-white mb-6">Our Mission</h2>
        <p class="text-gray-300 mb-4 leading-relaxed">
          At AstroFix, we believe that technology should empower, not frustrate. Our mission is to provide fast, reliable, and transparent repair services to keep your devices running at peak performance.
        </p>
        <p class="text-gray-300 leading-relaxed">
          We combine cutting-edge diagnostics with expert craftsmanship to deliver solutions that last. Whether it's a simple screen replacement or a complex motherboard repair, we handle every device with the utmost care.
        </p>
      </div>
      
      <div class="grid grid-cols-2 gap-6">
        <div class="bg-gray-900 p-6 rounded-2xl border border-borderGlass text-center">
          <div class="text-4xl font-bold text-primary mb-2">10+</div>
          <div class="text-gray-400">Years Experience</div>
        </div>
        <div class="bg-gray-900 p-6 rounded-2xl border border-borderGlass text-center">
          <div class="text-4xl font-bold text-primary mb-2">5k+</div>
          <div class="text-gray-400">Devices Repaired</div>
        </div>
        <div class="bg-gray-900 p-6 rounded-2xl border border-borderGlass text-center">
          <div class="text-4xl font-bold text-primary mb-2">100%</div>
          <div class="text-gray-400">Genuine Parts</div>
        </div>
        <div class="bg-gray-900 p-6 rounded-2xl border border-borderGlass text-center">
          <div class="text-4xl font-bold text-primary mb-2">24/7</div>
          <div class="text-gray-400">Customer Support</div>
        </div>
      </div>
    </div>
  </div>
</MainLayout>
