---
import MainLayout from '../../layouts/MainLayout.astro';
---

<MainLayout
  title="Buy Premium Laptops Qatar | AstroFix Sales"
  description="Shop for high-performance gaming, business, and refurbished laptops in Qatar."
>
  <div class="pt-32 pb-20 container mx-auto px-6 text-center">
    <h1 class="text-4xl md:text-6xl font-bold mb-6 text-white">Laptop Sales</h1>
    <p class="text-xl text-gray-400 max-w-2xl mx-auto">Explore our premium collection of gaming, business, and refurbished laptops.</p>
    <div class="mt-16 glass p-12 rounded-3xl border border-borderGlass">
      <h2 class="text-2xl font-bold text-white mb-4">Coming Soon</h2>
      <p class="text-gray-400">Our online catalog is currently being updated. Please contact us on WhatsApp for our latest inventory and pricing.</p>
    </div>
  </div>
</MainLayout>
