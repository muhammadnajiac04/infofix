---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="Contact Us | ScorpionFix Qatar">
  <!-- Page Banner -->
  <section class="bg-gray-100 pt-[100px] pb-12 border-b border-gray-200">
    <div class="container mx-auto px-4 md:px-6">
      <nav class="flex text-sm text-gray-500 mb-2" aria-label="Breadcrumb">
        <ol class="inline-flex items-center space-x-1 md:space-x-3">
          <li class="inline-flex items-center">
            <a href="/" class="hover:text-primary transition-colors">Home</a>
          </li>
          <li>
            <div class="flex items-center">
              <svg class="w-4 h-4 text-gray-400 mx-1" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"></path></svg>
              <span class="text-gray-700 font-medium">Contact Us</span>
            </div>
          </li>
        </ol>
      </nav>
      <h1 class="text-3xl md:text-4xl font-bold text-dark">Contact us</h1>
    </div>
  </section>

  <!-- Contact Form & Info -->
  <section class="py-12 md:py-16 bg-white">
    <div class="container mx-auto px-4 md:px-6">
      <div class="grid md:grid-cols-2 gap-12">
        <!-- Form Side -->
        <div class="animate-fade-in-up">
          <h2 class="text-2xl font-bold text-dark mb-6">Send Us a Message</h2>
          <form class="space-y-4">
            <div class="grid md:grid-cols-2 gap-4">
              <div>
                <input type="text" placeholder="Your Name" class="w-full px-4 py-3 border border-gray-300 rounded-md focus:outline-none focus:ring-1 focus:ring-primary focus:border-primary">
              </div>
              <div>
                <input type="email" placeholder="Your Email" class="w-full px-4 py-3 border border-gray-300 rounded-md focus:outline-none focus:ring-1 focus:ring-primary focus:border-primary">
              </div>
            </div>
            <div>
              <input type="tel" placeholder="Phone Number" class="w-full px-4 py-3 border border-gray-300 rounded-md focus:outline-none focus:ring-1 focus:ring-primary focus:border-primary">
            </div>
            <div>
              <textarea placeholder="Message" rows="5" class="w-full px-4 py-3 border border-gray-300 rounded-md focus:outline-none focus:ring-1 focus:ring-primary focus:border-primary"></textarea>
            </div>
            <button type="submit" class="bg-primary text-white font-bold py-3 px-8 rounded hover:bg-orange-600 transition-colors">
              Submit
            </button>
          </form>
        </div>

        <!-- Info Side -->
        <div class="animate-fade-in-up" style="animation-delay: 100ms;">
          <h2 class="text-2xl font-bold text-dark mb-6">Contact Information</h2>
          <div class="bg-light p-8 rounded-xl border border-gray-100 h-full">
            <ul class="space-y-6">
              <li class="flex items-start">
                <svg class="w-6 h-6 text-primary mr-4 mt-1 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"></path></svg>
                <div>
                  <h4 class="font-bold text-dark mb-1">Address</h4>
                  <p class="text-gray-600">63 Sofitel Complex, Wadi Msheireb St, Doha, Qatar</p>
                </div>
              </li>
              <li class="flex items-start">
                <img src="/img/support_icon.png" alt="Email" class="w-6 h-6 mr-4 mt-1 flex-shrink-0">
                <div>
                  <h4 class="font-bold text-dark mb-1">Email Address</h4>
                  <p class="text-gray-600">info@scorpionfixqa.com</p>
                </div>
              </li>
              <li class="flex items-start">
                <img src="/img/whatsapp-icon.png" alt="WhatsApp" class="w-6 h-6 mr-4 mt-1 flex-shrink-0">
                <div>
                  <h4 class="font-bold text-dark mb-1">Phone / WhatsApp</h4>
                  <p class="text-gray-600" dir="ltr">+974 3097 5205</p>
                </div>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>
</MainLayout>
