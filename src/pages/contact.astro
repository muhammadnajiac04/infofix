---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout
  title="Contact AstroFix | Get in Touch"
  description="Contact AstroFix in Doha, Qatar for laptop sales and repair inquiries. Call or WhatsApp us today."
>
  <div class="pt-32 pb-20 container mx-auto px-6">
    <div class="max-w-4xl mx-auto text-center mb-16">
      <h1 class="text-4xl md:text-6xl font-bold mb-6 text-white">Contact Us</h1>
      <p class="text-xl text-gray-400">Have a question or need a repair? Our team is ready to help.</p>
    </div>
    
    <div class="grid md:grid-cols-2 gap-12 max-w-5xl mx-auto">
      <div class="glass p-10 rounded-3xl border border-borderGlass">
        <h2 class="text-2xl font-bold text-white mb-8">Send Us a Message</h2>
        <form class="space-y-6">
          <div>
            <label class="block text-gray-400 mb-2 text-sm">Full Name</label>
            <input type="text" class="w-full bg-dark border border-borderGlass rounded-xl px-4 py-3 text-white focus:outline-none focus:border-primary transition-colors" placeholder="John Doe" />
          </div>
          <div>
            <label class="block text-gray-400 mb-2 text-sm">Email Address</label>
            <input type="email" class="w-full bg-dark border border-borderGlass rounded-xl px-4 py-3 text-white focus:outline-none focus:border-primary transition-colors" placeholder="john@example.com" />
          </div>
          <div>
            <label class="block text-gray-400 mb-2 text-sm">Message</label>
            <textarea rows="4" class="w-full bg-dark border border-borderGlass rounded-xl px-4 py-3 text-white focus:outline-none focus:border-primary transition-colors" placeholder="How can we help you?"></textarea>
          </div>
          <button type="button" class="w-full bg-primary hover:bg-indigo-500 text-white font-bold py-4 rounded-xl shadow-neon transition-colors">
            Send Message
          </button>
        </form>
      </div>
      
      <div class="space-y-8">
        <div class="bg-gray-900 p-8 rounded-3xl border border-borderGlass flex items-start gap-6">
          <div class="text-4xl">📍</div>
          <div>
            <h3 class="text-xl font-bold text-white mb-2">Visit Our Shop</h3>
            <p class="text-gray-400">Main Street, Tech District<br/>Doha, Qatar</p>
          </div>
        </div>
        
        <div class="bg-gray-900 p-8 rounded-3xl border border-borderGlass flex items-start gap-6">
          <div class="text-4xl">📞</div>
          <div>
            <h3 class="text-xl font-bold text-white mb-2">Call Us</h3>
            <p class="text-gray-400">+974 XXXXXXXX</p>
            <p class="text-sm text-primary mt-2">Available 9AM - 10PM</p>
          </div>
        </div>
        
        <div class="bg-gray-900 p-8 rounded-3xl border border-borderGlass flex items-start gap-6">
          <div class="text-4xl">✉️</div>
          <div>
            <h3 class="text-xl font-bold text-white mb-2">Email Us</h3>
            <p class="text-gray-400">support@astrofix.com</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</MainLayout>
